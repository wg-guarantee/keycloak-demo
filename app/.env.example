# ============================================================
# .env.example  –  Copy to .env and fill in real values
# ============================================================

# ── Keycloak connection ────────────────────────────────────
# NodePort URL (from K8S deployment, port 30080)
KEYCLOAK_URL=http://113.44.80.20:30080

# Realm name (created by scripts/setup_realm.py)
REALM=demo

# OIDC Client ID (must match what setup_realm.py created)
CLIENT_ID=demo-app

# Public PKCE client has no secret – leave blank
CLIENT_SECRET=

# ── Application ────────────────────────────────────────────
# Base URL where *this* app is reachable (used for redirect_uri)
APP_BASE_URL=http://localhost:8000

# Session signing secret – generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_HEX_CHARS
