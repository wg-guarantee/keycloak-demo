# ============================================================
# .env.example  –  Docker Compose 环境变量配置模板
# 使用方法：cp .env.example .env，然后填入真实值
# ============================================================

# ── Keycloak 对外访问地址（浏览器和 JWT Issuer 使用）────────
# 填写部署服务器的真实 IP 或域名
KEYCLOAK_HOST=43.161.250.138
KEYCLOAK_PORT=8080

# ── PostgreSQL ───────────────────────────────────────────────
# 建议修改为更强的密码
POSTGRES_PASSWORD=**********

# ── Keycloak 管理员账号（首次启动初始化）──────────────────────
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=**********

# ── 腾讯云 SMS ────────────────────────────────────────────────
# 获取地址：https://console.cloud.tencent.com/cam/capi
TENCENT_SMS_SECRET_ID=YOUR_TENCENT_SECRET_ID
TENCENT_SMS_SECRET_KEY=YOUR_TENCENT_SECRET_KEY

# 短信控制台 → 应用列表 → SDKAppID
TENCENT_SMS_APP_ID=YOUR_SMS_APP_ID

# 已审核通过的短信签名名称（不含【】符号）
TENCENT_SMS_SIGN_NAME=YOUR_SMS_SIGN_NAME

# 已审核通过的模板 ID，模板示例：验证码{1}，5分钟内有效
TENCENT_SMS_TEMPLATE_ID=YOUR_SMS_TEMPLATE_ID

# 腾讯云 SMS 地域
TENCENT_SMS_REGION=ap-guangzhou

# ── SMTP 邮件（用于邮箱激活 / 忘记密码）──────────────────────
# 留空则关闭邮件功能；填写后注册流程将要求邮箱激活
# Gmail 示例：需要开启两步验证并生成「应用专用密码」
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Keycloak Realm / Client（与 setup_realm.py 保持一致）────
REALM=demo
CLIENT_ID=demo-app

# ── FastAPI 应用 ──────────────────────────────────────────────
# 应用对外访问地址（用于 OIDC redirect_uri 回调）
APP_BASE_URL=http://localhost:8000

# Session 签名密钥（随机 64 位十六进制字符串）
# 生成命令：python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF_ABOVE_COMMAND

# 应用监听端口（可选，默认 8000）
APP_PORT=8000
